{
  "type": "FormPage",
  "schema": {
    "title": {
      "type": "PageTitle",
      "schema": {
        "localizeTitle": true,
        "description": "/form-sample/parents/new:Description",
        "actions": [
          {
            "type": "Button",
            "schema": {
              "label": "Back",
              "variant": "text"
            },
            "action": {
              "type": "Local",
              "composable": "useRedirect",
              "options": {
                "type": "Inline",
                "value": {
                  "back": true
                }
              }
            }
          }
        ]
      },
      "data": {
        "type": "Inline",
        "value": "/form-sample/parents/new:Title"
      }
    },
    "submit": {
      "label": "Save",
      "severity": "primary"
    },
    "sections": [
      {
        "key": "default",
        "label": "Default",
        "inputGroups": [
          {
            "key": "name",
            "inputs": [
              {
                "name": "name",
                "component": {
                  "type": "InputText",
                  "schema": {
                    "label": {
                      "text": "Name",
                      "mode": "ifta",
                      "showOptionality": true
                    }
                  }
                }
              }
            ],
            "wide": true
          },
          {
            "key": "surname",
            "inputs": [
              {
                "name": "surname",
                "required": true,
                "component": {
                  "type": "InputText",
                  "schema": {
                    "label": {
                      "text": "Surname",
                      "mode": "ifta",
                      "showOptionality": true
                    }
                  }
                }
              }
            ],
            "wide": true
          },
          {
            "key": "role",
            "inputs": [
              {
                "name": "role",
                "component": {
                  "type": "Select",
                  "schema": {
                    "label": {
                      "text": "Role",
                      "mode": "ifta",
                      "showOptionality": true
                    },
                    "localizeOptionLabels": true,
                    "optionLabel": "label",
                    "optionValue": "value",
                    "showClear": true
                  },
                  "data": {
                    "type": "Inline",
                    "value": [
                      {
                        "label": "Role.Admin",
                        "value": "Admin"
                      },
                      {
                        "label": "Role.Moderator",
                        "value": "Moderator"
                      },
                      {
                        "label": "Role.Writer",
                        "value": "Writer"
                      },
                      {
                        "label": "Role.Maintainer",
                        "value": "Maintainer"
                      }
                    ]
                  }
                }
              }
            ],
            "wide": true
          },
          {
            "key": "status",
            "inputs": [
              {
                "name": "status",
                "component": {
                  "type": "SelectButton",
                  "schema": {
                    "allowEmpty": true,
                    "label": {
                      "text": "Status",
                      "mode": "ifta",
                      "showOptionality": true
                    },
                    "localizeOptionLabels": true,
                    "optionLabel": "label",
                    "optionValue": "value"
                  },
                  "data": {
                    "type": "Inline",
                    "value": [
                      {
                        "label": "Status.Active",
                        "value": "Active"
                      },
                      {
                        "label": "Status.Passive",
                        "value": "Passive"
                      }
                    ]
                  }
                }
              }
            ],
            "wide": true
          },
          {
            "key": "description",
            "inputs": [
              {
                "name": "description",
                "component": {
                  "type": "InputText",
                  "schema": {
                    "label": {
                      "text": "Description",
                      "mode": "ifta",
                      "showOptionality": true
                    }
                  }
                }
              }
            ],
            "wide": true
          }
        ]
      }
    ],
    "validations": [
      {
        "name": "useFormSampleValidation"
      }
    ],
    "path": "form-sample/parents/new"
  },
  "action": {
    "type": "Remote",
    "path": "form-sample/parents",
    "method": "POST",
    "body": {
      "type": "Context",
      "key": "model"
    },
    "postAction": {
      "type": "Local",
      "composable": "useRedirect",
      "options": {
        "type": "Inline",
        "value": {
          "route": "/form-sample"
        }
      }
    }
  }
}