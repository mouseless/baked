documentation-samples @controller-model {
  execute {
    @action-model route="POST /documentation-samples" required-claims="BaseA, BaseB"
    parameter {
      @parameter-model required=#true
    }
  }
}

documentation-samples @controller-model {
  method {
    @action-model route="POST /documentation-samples/method" required-claims="BaseA, BaseB"
    parameter1 {
      @parameter-model required=#true
    }
    parameter2 {
      @parameter-model required=#true
    }
  }
  parameterless-method {
    @action-model route="POST /documentation-samples/parameterless-method" required-claims="BaseA, BaseB"
  }
  array-and-generic-parameters {
    @action-model route="POST /documentation-samples/array-and-generic-parameters" required-claims="BaseA, BaseB"
    enumerable {
      @parameter-model required=#true
    }
    array {
      @parameter-model required=#true
    }
    dictionary {
      @parameter-model required=#true
    }
  }
  route {
    @action-model route="POST /documentation-samples/route/{route}" required-claims="BaseA, BaseB"
    route {
      @parameter-model required=#true in="route"
    }
  }
  multiline {
    @action-model route="POST /documentation-samples/multiline" required-claims="BaseA, BaseB"
  }
}

