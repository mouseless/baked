child {
  @controller-model groupName="Childrens"
  update {
    @action-model method="PUT" route="children/{id}/"
    name @parameter-model
    parent @parameter-model
    parentWrapper @parameter-model
  }
}

children {
  @controller-model groupName="Children"
  by {
    @action-model method="GET" route="children"
  }
  first-by {
    @action-model method="GET" route="children/first"
    fetchParents {
      @parameter-model in="query"
    }
  }
}

