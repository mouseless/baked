route-parameters-sample {
  @controller-model groupName="RouteParametersSamples"
  with {
    @action-model method="GET" route="route-parameters-samples/{id}"
    id {
      @parameter-model required=#true in="route"
    }
  }
  get-items {
    @action-model method="GET" route="route-parameters-samples/{id}/items"
  }
}

