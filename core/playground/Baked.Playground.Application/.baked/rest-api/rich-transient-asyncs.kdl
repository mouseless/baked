rich-transient-async @controller-model {
  with {
    @action-model route="GET /rich-transient-asyncs/{id}" required-claims="BaseA, BaseB"
    id {
      @parameter-model required=#true in="route"
    }
  }
}

rich-transient-async-extension @controller-model {
  from-extension {
    @action-model route="POST /rich-transient-asyncs/{id}/from-extension" required-claims="BaseA, BaseB"
  }
}

