create-bulk-command @controller-model {
  execute {
    @action-model route="PATCH /bulk-command" flat-request-body=#true required-claims="BaseA, BaseB"
    descriptors {
      @parameter-model required=#true
    }
  }
}

sync-bulk-command @controller-model {
  execute {
    @action-model route="PUT /bulk-command" flat-request-body=#true required-claims="BaseA, BaseB"
    descriptors {
      @parameter-model required=#true
    }
  }
}

