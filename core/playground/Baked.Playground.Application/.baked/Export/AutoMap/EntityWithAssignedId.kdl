entity-with-assigned-id @entity {
  id {
    @id routeName="id" mapping="MappingOptions { UserType = Baked.CodingStyle.Id.IdStringUserType, IdentifierGenerator = NHibernate.Id.Assigned }"
  }
}

entity-with-assigned-ids {
  @query locatableType="Baked.Playground.CodingStyle.Id.EntityWithAssignedId"
}

